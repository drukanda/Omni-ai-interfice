const { GoogleGenerativeAI } = require("@google/generative-ai");

module.exports = async (req, res) => {
  if (req.method === 'GET') {
    res.setHeader('Content-Type', 'text/html');
    return res.send(`
      <!DOCTYPE html>
      <html>
      <head>
        <title>OMNI SINGULARITY</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <style>
          body { background: #000; color: #00f2ff; font-family: monospace; margin: 0; display: flex; flex-direction: column; height: 100vh; }
          #chat { flex: 1; overflow-y: auto; padding: 20px; }
          input { width: 100%; background: #000; border: none; border-top: 1px solid #00f2ff; color: #00f2ff; padding: 15px; outline: none; font-family: inherit; box-sizing: border-box; }
          .u { color: #fff; margin: 10px 0; }
          .a { color: #00f2ff; margin-bottom: 20px; border-left: 2px solid #00f2ff; padding-left: 10px; }
        </style>
      </head>
      <body>
        <div style="font-size:10px; padding:10px; border-bottom:1px solid #1a1a1a;">SYSTEM: OMNI-AI V8.0 ONLINE</div>
        <div id="chat"></div>
        <input type="text" id="i" placeholder="INPUT COMMAND..." onkeypress="sh(event)">
        <script>
          async function sh(e) {
            if (e.key === 'Enter' && e.target.value) {
              const v = e.target.value;
              const c = document.getElementById('chat');
              c.innerHTML += '<div class="u">> ' + v + '</div>';
              e.target.value = '';
              const res = await fetch('/api', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ p: v })
              });
              const d = await res.json();
              c.innerHTML += '<div class="a">' + (d.r || d.e) + '</div>';
              c.scrollTop = c.scrollHeight;
            }
          }
        </script>
      </body>
      </html>
    `);
  }

  try {
    const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);
    const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });
    const result = await model.generateContent(req.body.p);
    res.status(200).json({ r: result.response.text() });
  } catch (err) {
    res.status(500).json({ e: "ERROR: Check API Key in Vercel" });
  }
};
